# Server
APP_PORT=8080
APP_MODE=debug

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sim_sekolah
DB_SSLMODE=disable

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173

# Upload
UPLOAD_DIR=./uploads

# JWT
JWT_SECRET=ubah-secret-ini-di-production
JWT_TTL_HOURS=24

# Branding default (dapat ditimpa dari database per instance)
BRANDING_SCHOOL_NAME=Nama Sekolah
BRANDING_PRIMARY_COLOR=#2563eb

# Data dummy development
SEED_DUMMY=false
